{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testEnvironment": "node",
  "testRegex": "test/.*\\.e2e-spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": ["ts-jest", { "isolatedModules": true }]
  },
  "transformIgnorePatterns": ["/node_modules/\\.pnpm/(?!uuid@)"],
  "testTimeout": 120000,
  "maxWorkers": 1
}
