model Assessment {
  id                  String               @id @default(cuid())
  childId             String
  ageGroup            String
  status              AssessmentStatus     @default(IN_PROGRESS)

  // ─── Who is reporting? (F4 — multi-informant) ───────────────────────────────
  //
  // Defaults to PARENT because every screening that existed before this column did
  // was guardian-administered: assessments.service threw unless the caller owned the
  // child's profile. The default is a statement of fact about the backfill, not a
  // convenience.
  informantType   InformantType @default(PARENT)
  /// The USER who actually answered the questions. Null only for legacy rows whose
  /// guardian could not be resolved — reported, never guessed.
  respondentId    String?
  respondent      User?         @relation("AssessmentRespondent", fields: [respondentId], references: [id], onDelete: SetNull)
  /// The setting in which it was administered. Null for a parent screening at home.
  facilityId      String?
  facility        Facility?     @relation("FacilityAssessments", fields: [facilityId], references: [id], onDelete: SetNull)
  tier1Completed      Boolean              @default(false)
  tier2Completed      Boolean              @default(false)
  tier1CompletedAt    DateTime?
  tier2CompletedAt    DateTime?
  completedAt         DateTime?
  expiresAt           DateTime?
  overallScore        Float?
  domainScores        Json?
  flaggedDomains      String[]             @default([])
  reportGenerated     Boolean              @default(false)
  reportGeneratedAt   DateTime?
  v2ReportGenerated   Boolean              @default(false)
  v2ReportGeneratedAt DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  reports             AssessmentReport[]
  responses           AssessmentResponse[]
  shares              AssessmentShare[]
  child               Child                @relation(fields: [childId], references: [id], onDelete: Cascade)
  worksheets          Worksheet[]          @relation("WorksheetScreening")

  @@index([childId])
  @@index([status])
  @@index([createdAt])
  // The concordance query: "every screening of this child, by informant".
  @@index([childId, informantType])
  @@index([facilityId])
  @@map("assessments")
}

