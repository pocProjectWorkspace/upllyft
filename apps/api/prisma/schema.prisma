// ═══════════════════════════════════════════════════════════════════════════
// MULTI-SETTING TENANCY  (docs/tenancy-and-multi-setting-model.md — Phase B)
//
// One child record; every party holds a scoped, consented, time-bounded LENS
// onto it. B2C and B2B are two go-to-market motions over one model, not two
// architectures — the parent is simply the widest lens (the guardian).
//
// ADDITIVE. Nothing reads these yet. `Clinic` remains the live model until the
// readers are migrated (Phase D); each Clinic is backfilled to a Facility with
// the SAME id, so foreign keys can be repointed later without rewriting ids.
//
// The root problem being fixed: `Child.clinicId` is a single nullable FK, so a
// child enrolled at a nursery AND referred to a clinic cannot be both — which
// is precisely the referral loop the nursery proposition depends on.
// `ChildAffiliation` replaces it. Everything else follows from that.
// ═══════════════════════════════════════════════════════════════════════════

enum OrgKind {
  CLINIC_GROUP
  NURSERY_GROUP
  SCHOOL_GROUP
  NGO
  PLATFORM
}

enum FacilityType {
  CLINIC // treats: cases, clinical notes, diagnosis
  NURSERY // observes: no case, no note, no diagnosis — ever
  SCHOOL
}

enum AffiliationType {
  PATIENT // clinical relationship
  ENROLLED // educational relationship
}

enum AffiliationStatus {
  PENDING_CONSENT // facility added the child; guardian has not yet consented
  ACTIVE
  ENDED
}

/// What a facility may see about an affiliated child. Ordered least → most.
/// An affiliation may never exceed its FacilityType's ceiling (`maxDataScope`).
/// A NURSERY defaults to OBSERVATIONS_ONLY — that is HOW we guarantee a nursery
/// never sees a diagnosis: structurally, not by remembering to check.
enum DataScope {
  OBSERVATIONS_ONLY // own observations + own screenings
  SCREENING_SHARED // + screenings the guardian shared back
  CLINICAL_SUMMARY // + strategies/recommendations, NEVER the diagnosis
  FULL_CLINICAL // clinic default
}

enum FacilityRole {
  OWNER
  ADMIN
  CLINICAL_LEAD
  THERAPIST
  INCLUSION_LEAD // nursery SENCO — owns flag → conversation → referral
  KEYWORKER // nursery room staff — observes
  RECEPTION
  BILLING
}

/// A typed site where children are seen. Generalises `Clinic`.
/// Unlike Clinic: `organizationId` is REQUIRED (every facility belongs to an
/// account) and there is no `adminId @unique` — administration comes from
/// FacilityMember, so a group may run many sites and a person may administer
/// several. Both were hard blockers on modelling a nursery chain.
model Facility {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  type FacilityType
  name String
  slug String       @unique

  // Regulatory context. `licenseAuthority` must be type-appropriate — enforced
  // in the service layer, not the DB (Postgres cannot express the cross-column
  // constraint against an enum cleanly).
  licenseNo            String?
  licenseAuthority     LicenseAuthority?
  emirate              Emirate?
  complianceStatus     FacilityComplianceStatus @default(DRAFT)
  complianceReviewedAt DateTime?
  complianceReviewedBy String?

  // Presentation
  logoUrl      String?
  primaryColor String?
  address      String?
  phone        String?
  email        String?

  /// Set during the Clinic→Facility backfill; lets Phase D reconcile and lets us
  /// prove the 1:1 mapping held. Null for facilities created natively (nurseries).
  migratedFromClinicId String? @unique

  members          FacilityMember[]
  rooms            Room[]
  affiliations     ChildAffiliation[]
  consents         ChildConsent[]
  claims           ChildClaim[]
  assessments      Assessment[]       @relation("FacilityAssessments")
  observations     Observation[]      @relation("FacilityObservations")
  concerns         Concern[]          @relation("FacilityConcerns")
  supportPlans     SupportPlan[]      @relation("FacilitySupportPlans")
  developmentalReviews DevelopmentalReview[] @relation("FacilityDevReviews")
  handoverRecords      HandoverRecord[]      @relation("FacilityHandovers")
  consentTemplates ConsentTemplate[]  @relation("FacilityConsentTemplates")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([type])
  @@index([complianceStatus])
  @@map("facilities")
}

/// A room / class group within a nursery or school. The cohort primitive —
/// gives us a roster with NO new tenancy concept.
model Room {
  id         String   @id @default(cuid())
  facilityId String
  facility   Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)

  name         String // "Butterflies"
  ageBandLabel String? // "2–3 years"

  affiliations ChildAffiliation[]
  staff        FacilityMember[]   @relation("RoomStaff")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([facilityId, name])
  @@index([facilityId])
  @@map("rooms")
}

/// Staff ↔ facility. Replaces `Clinic.adminId @unique` and `TherapistProfile.clinicId`.
model FacilityMember {
  id         String       @id @default(cuid())
  facilityId String
  facility   Facility     @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  userId     String
  user       User         @relation("FacilityMemberships", fields: [userId], references: [id], onDelete: Cascade)
  role       FacilityRole
  status     MemberStatus @default(ACTIVE)

  rooms        Room[]             @relation("RoomStaff")
  keyworkerFor ChildAffiliation[] @relation("AffiliationKeyworker")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, facilityId])
  @@index([facilityId, role])
  @@index([userId])
  @@map("facility_members")
}

/// Consent, generalised from Case to CHILD + FACILITY (Phase E).
///
/// `CaseConsent` already had the right shape — versioned, guardian-granted,
/// purpose-bound, revocable. It was merely keyed to a Case, which a nursery will
/// never have: a nursery observes an enrolled child, it does not open cases.
///
/// The grant reads: *this guardian permits THIS FACILITY to do THIS, for THIS
/// purpose, until THIS date, revocably.* That is what makes consent an access
/// GATE rather than a stored form — and it is the thing a nursery's procurement
/// review will actually scrutinise.
///
/// Additive: `CaseConsent` remains until its readers migrate. Rows are backfilled
/// 1:1 with `migratedFromCaseConsentId` recording provenance.
model ChildConsent {
  id      String @id @default(cuid())
  childId String
  child   Child  @relation(fields: [childId], references: [id], onDelete: Cascade)

  // WHO granted it. A guardian must hold `hasAuthorityToConsent`; grantedBy is
  // retained for audit even when the guardian record is the authority.
  guardianId  String?
  guardian    Guardian? @relation("ChildConsentGuardian", fields: [guardianId], references: [id])
  grantedById String
  grantedBy   User      @relation("ChildConsents", fields: [grantedById], references: [id])

  // TO WHOM. A facility-scoped grant is the nursery/clinic case; caseId is kept so
  // clinical consents can still point at the case they were captured on.
  facilityId    String?
  facility      Facility?         @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  affiliationId String?
  affiliation   ChildAffiliation? @relation(fields: [affiliationId], references: [id], onDelete: SetNull)
  caseId        String?

  type      ConsentType
  purpose   String?
  recipient String?
  scope     Json?

  consentVersionId String?
  consentVersion   ConsentVersion? @relation("ChildConsentVersion", fields: [consentVersionId], references: [id])

  validFrom  DateTime  @default(now())
  validUntil DateTime?
  revokedAt  DateTime?
  notes      String?

  /// Provenance for the CaseConsent -> ChildConsent backfill; proves the 1:1 held.
  migratedFromCaseConsentId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([childId, type])
  @@index([facilityId])
  @@index([affiliationId])
  @@index([guardianId])
  @@map("child_consents")
}

/// THE load-bearing model. Replaces the single nullable `Child.clinicId`.
///
/// A child holds N affiliations CONCURRENTLY — enrolled at a nursery while a
/// patient at a clinic is the normal case, not an edge case. Every access
/// decision routes through here, which is what makes the unsafe query the hard
/// one to write.
model ChildAffiliation {
  id         String   @id @default(cuid())
  childId    String
  child      Child    @relation(fields: [childId], references: [id], onDelete: Cascade)
  facilityId String
  facility   Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)

  type      AffiliationType
  status    AffiliationStatus @default(PENDING_CONSENT)
  dataScope DataScope         @default(OBSERVATIONS_ONLY)

  startedAt DateTime  @default(now())
  endedAt   DateTime?

  // Nursery cohort placement (null for clinics)
  roomId      String?
  room        Room?           @relation(fields: [roomId], references: [id], onDelete: SetNull)
  keyworkerId String?
  keyworker   FacilityMember? @relation("AffiliationKeyworker", fields: [keyworkerId], references: [id], onDelete: SetNull)

  consents     ChildConsent[]
  claims       ChildClaim[]
  observations Observation[]
  concerns     Concern[]
  supportPlans SupportPlan[]
  developmentalReviews DevelopmentalReview[]
  handoverRecords      HandoverRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // A child may hold many affiliations, but only one per facility per start date.
  // (Re-enrolment after ENDED gets a new startedAt.)
  @@unique([childId, facilityId, startedAt])
  @@index([childId])
  @@index([facilityId, status])
  @@index([roomId])
  @@index([keyworkerId])
  @@map("child_affiliations")
}

// ─── Parent claim (F3) ───────────────────────────────────────────────────────

enum ChildClaimStatus {
  PENDING /// invite sent; guardian has not acted
  ACCEPTED /// guardian claimed the child (adopted the placeholder, or merged into their own)
  DISPUTED /// guardian says this is not their child — the facility must be told
  EXPIRED
  REVOKED /// the facility withdrew it (child left before claiming, entered in error)
}

/// A nursery-created child, awaiting the guardian who can speak for them.
///
/// THE PROBLEM THIS SOLVES: most nursery children have no parent on Upllyft, but
/// `Child.profileId` is a required FK to a parent's `UserProfile`. The walk-in
/// precedent solved this by minting a `User` on the guardian's REAL email with no
/// password — which left that guardian unable to register ("user already exists")
/// AND unable to log in ("invalid credentials"), with only an undiscoverable
/// password-reset as the way in. We do not repeat that.
///
/// Instead the placeholder child hangs off a SYNTHETIC shadow profile, and the
/// guardian's real email lives HERE and on the `Guardian` row — never on a `User`.
/// So the guardian's own email is still free when they come to sign up, and the
/// account they end up with is one they knowingly created.
///
/// THE TOKEN IS THE CREDENTIAL. Only its SHA-256 is stored: a leaked database must
/// not yield working claim links. It is single-use and expiring.
model ChildClaim {
  id        String @id @default(cuid())
  tokenHash String @unique

  /// The child this claim is FOR. Points at the placeholder until the claim
  /// resolves; on a merge it is repointed to the guardian's real child and the
  /// placeholder is deleted, so this always names the surviving record.
  childId String
  child   Child  @relation("ChildClaims", fields: [childId], references: [id], onDelete: Cascade)

  affiliationId String
  affiliation   ChildAffiliation @relation(fields: [affiliationId], references: [id], onDelete: Cascade)

  facilityId String
  facility   Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)

  /// The guardian's REAL contact details. Deliberately NOT a User row — see above.
  guardianEmail String
  guardianName  String

  status    ChildClaimStatus @default(PENDING)
  expiresAt DateTime

  claimedAt       DateTime?
  claimedByUserId String?
  claimedBy       User?     @relation("ClaimedChildClaims", fields: [claimedByUserId], references: [id], onDelete: SetNull)

  /// Audit: the placeholder that was deleted when this claim merged into an
  /// existing child. Plain string, not an FK — the row it names is gone.
  mergedFromPlaceholderId String?

  /// Why the guardian disputed it, in their words.
  disputeReason String?

  createdById String
  createdBy   User   @relation("CreatedChildClaims", fields: [createdById], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([facilityId, status])
  @@index([guardianEmail])
  @@index([childId])
  @@map("child_claims")
}

// ─── Continuous observation capture (F5) ─────────────────────────────────────

enum ObservationType {
  NOTE /// a general note about the day
  MOMENT /// a nice developmental moment / progress worth recording
  MILESTONE /// a milestone reached
  CONCERN /// the keyworker is worried about something — seeds the F6 concern→conversation pathway
}

/// A single developmental observation, recorded by a keyworker about an enrolled child.
///
/// THIS IS NOT A CLINICAL RECORD, and it is deliberately a separate model rather than a
/// caseless `ClinicalRecord`. A nursery observes; it does not treat. It has no case, no
/// diagnosis, no discipline, no therapist signature — the capability map grants a nursery
/// `canObserve` and denies it `canWriteClinicalNotes`, and the data model mirrors that
/// split rather than blurring it. Widening `ClinicalRecord.caseId` to null would force
/// every clinical reader to defend against a caseless record.
///
/// ANCHORED TO THE AFFILIATION, which is the consent anchor. There is no path to an
/// observation that does not route through a `ChildAffiliation`, so the consent gate
/// applies by construction: an observation can only be WRITTEN while the affiliation is
/// ACTIVE (consent granted), and nursery staff can only READ it while that consent
/// stands. This is also what keeps the F3 placeholder-merge safe — "a PENDING_CONSENT
/// affiliation accrues no data" holds because observations require ACTIVE.
///
/// DOMAIN-TAGGED with the same 8-domain vocabulary the screening uses, so observations
/// accumulate as corroborating evidence against the same domains a screening flags —
/// which is what the F6 coached conversation is built on.
model Observation {
  id      String @id @default(cuid())
  childId String
  child   Child  @relation("ChildObservations", fields: [childId], references: [id], onDelete: Cascade)

  // The enrolment this was observed under. The consent anchor — deleting it (a child
  // leaving) takes the observations with it, because they were only ever visible through it.
  affiliationId String
  affiliation   ChildAffiliation @relation(fields: [affiliationId], references: [id], onDelete: Cascade)

  // Denormalised for direct, fail-closed scoping without a join through the affiliation.
  facilityId String
  facility   Facility @relation("FacilityObservations", fields: [facilityId], references: [id], onDelete: Cascade)

  // WHO observed it — the keyworker, as a User. SetNull so a departing staff member does
  // not delete the developmental history of a child they observed.
  authorId String?
  author   User?   @relation("ObservationAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  /// One of the 8 developmental domains, or null for a general note not tied to one.
  domain     String?
  type       ObservationType @default(NOTE)
  note       String
  /// WHEN it was observed — may differ from createdAt (a keyworker writing up the morning
  /// at lunchtime). Continuous capture is dated by this, not by the row's creation.
  observedAt DateTime        @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([childId, observedAt])
  @@index([facilityId, observedAt])
  @@index([affiliationId])
  @@index([domain])
  @@map("observations")
}

// ─── The coached teacher → parent conversation (F6) ──────────────────────────

enum ConcernStatus {
  DRAFT /// the inclusion lead is preparing it — coaching generated, summary still editable
  SHARED /// shared with the guardian
  ACKNOWLEDGED /// the guardian has seen it (and may have responded)
  CLOSED /// resolved, or handed onward to a referral
}

/// A concern a nursery raises with a child's parent, and the coaching that surrounds it.
///
/// This is the last step of the nursery proposition: an inclusion lead has accumulated
/// evidence (CONCERN observations, a screening flag, a home-vs-nursery disagreement) and
/// now has to have the hardest conversation in early years — telling a parent their child
/// might be struggling. It is easy to do badly: to alarm, to label, to sound like an
/// accusation. So the platform COACHES the lead (privately) on how to raise it, and helps
/// draft a warm, specific, non-diagnostic message the parent actually receives.
///
/// Anchored to the affiliation (the consent anchor). Raising requires an ACTIVE, consented
/// enrolment; the guardian can always see concerns shared with them about their own child.
model Concern {
  id      String @id @default(cuid())
  childId String
  child   Child  @relation("ChildConcerns", fields: [childId], references: [id], onDelete: Cascade)

  affiliationId String
  affiliation   ChildAffiliation @relation(fields: [affiliationId], references: [id], onDelete: Cascade)
  facilityId    String
  facility      Facility         @relation("FacilityConcerns", fields: [facilityId], references: [id], onDelete: Cascade)

  /// The inclusion lead who raised it. SetNull so their leaving does not erase the record.
  raisedById String?
  raisedBy   User?   @relation("ConcernRaiser", fields: [raisedById], references: [id], onDelete: SetNull)

  status  ConcernStatus @default(DRAFT)
  /// The developmental domains the concern is about (the same 8-domain vocabulary).
  domains String[]      @default([])

  /// PRIVATE to staff — how to have the conversation. Never shown to the parent.
  staffCoaching String?
  coachingModel String?
  /// The message shared WITH the parent. AI-drafted, editable by staff before sharing.
  parentSummary String

  /// A snapshot of what the concern rests on — counts + refs, not duplicated PHI.
  /// { concernObservations: n, assessmentId?: string, flaggedDomains?: string[] }
  evidenceSummary Json?

  sharedAt       DateTime?
  acknowledgedAt DateTime?
  parentResponse String?

  /// A concern may lead to an in-setting support plan (F6 → F7).
  supportPlans SupportPlan[] @relation("ConcernSupportPlans")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([childId, status])
  @@index([facilityId, status])
  @@map("concerns")
}

// ─── In-setting support & the graduated approach (F7) ────────────────────────

enum SupportPlanStatus {
  DRAFT /// the lead is drafting it — not yet shared
  ACTIVE /// shared with the parent; support is underway
  UNDER_REVIEW /// a review cycle is in progress
  CLOSED /// concluded — outcomes met, or handed onward to a referral
}

enum SupportReviewDecision {
  CONTINUE /// support is working — keep going
  ADJUST /// change the outcomes or the interventions
  ESCALATE /// in-setting support is not enough — refer on
  CLOSE /// outcomes met — close the plan
}

/// A nursery's in-setting support plan for an enrolled child — the "Do → Review" of the
/// graduated approach (Assess → Plan → Do → Review), the step AFTER a concern (F6).
///
/// NOT an IEP. `IEP`/`MilestonePlan` hang off a `Case`, and a nursery has no case. This is
/// its own model anchored to the affiliation (the consent anchor), following the F5/F6
/// pattern: created only while the affiliation is ACTIVE + consented, read by staff only
/// while that consent stands, and always visible to the guardian once shared. It reuses the
/// `GoalBankItem` vocabulary and the IEP goal/versioning SHAPES — not the case-bound tables.
model SupportPlan {
  id      String @id @default(cuid())
  childId String
  child   Child  @relation("ChildSupportPlans", fields: [childId], references: [id], onDelete: Cascade)

  affiliationId String
  affiliation   ChildAffiliation @relation(fields: [affiliationId], references: [id], onDelete: Cascade)
  facilityId    String
  facility      Facility         @relation("FacilitySupportPlans", fields: [facilityId], references: [id], onDelete: Cascade)

  /// The concern this plan responds to, where it grew from one (F6 → F7). Optional: a lead
  /// may also open a plan directly from accumulated observations / screening flags.
  concernId String?
  concern   Concern? @relation("ConcernSupportPlans", fields: [concernId], references: [id], onDelete: SetNull)

  /// The lead who owns it. SetNull so their leaving does not erase the record.
  createdById String?
  createdBy   User?   @relation("CreatedSupportPlans", fields: [createdById], references: [id], onDelete: SetNull)

  title   String
  status  SupportPlanStatus @default(DRAFT)
  /// The developmental domains the plan addresses (the same 8-domain vocabulary).
  domains String[]          @default([])

  /// A short, parent-facing summary of what the nursery is doing and why — shared with the
  /// guardian. Staff-private working notes live in `staffNotes`, never on the guardian path.
  summary    String?
  staffNotes String?

  /// When the next review is due. The graduated approach is a CYCLE, not a one-off.
  reviewDate DateTime?

  sharedAt       DateTime?
  acknowledgedAt DateTime?
  parentResponse String?

  version           Int          @default(1)
  previousVersionId String?      @unique
  previousVersion   SupportPlan? @relation("SupportPlanVersioning", fields: [previousVersionId], references: [id])
  nextVersion       SupportPlan? @relation("SupportPlanVersioning")

  outcomes SupportOutcome[]
  reviews  SupportReview[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([childId, status])
  @@index([facilityId, status])
  @@index([affiliationId])
  @@index([concernId])
  @@map("support_plans")
}

/// One targeted outcome within a support plan. Mirrors the `IEPGoal` measurability shape,
/// and reuses `GoalStatus`. Outcomes hold LIVE state; `SupportReview` snapshots their
/// history at each review point.
model SupportOutcome {
  id     String      @id @default(cuid())
  planId String
  plan   SupportPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  domain      String
  outcomeText String
  /// How we'll know it's working — a short, observable success measure.
  successCriteria String?

  baselineValue      Float?
  targetDate         DateTime?
  reviewIntervalDays Int?
  currentProgress    Float      @default(0)
  status             GoalStatus @default(NOT_STARTED)
  order              Int        @default(0)

  interventions SupportIntervention[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([planId])
  @@index([status])
  @@map("support_outcomes")
}

/// A review point in the plan's cycle — the "Review" of Assess-Plan-Do-Review. Records the
/// decision (continue / adjust / escalate to referral / close) and a snapshot of where each
/// outcome stood, so the history survives even as the live outcomes move on.
model SupportReview {
  id     String      @id @default(cuid())
  planId String
  plan   SupportPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  reviewedById String?
  reviewedBy   User?   @relation("SupportPlanReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  /// Per-outcome snapshot at this review: [{ outcomeId, progress, status }].
  outcomeProgress  Json?
  progressNote     String?
  decision         SupportReviewDecision
  /// Whether this review was shared with the parent (a review can update them, or be internal).
  sharedWithParent Boolean               @default(false)

  reviewedAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([planId])
  @@map("support_reviews")
}

// ─── Targeted interventions & home strategies (F8) ───────────────────────────

enum InterventionKind {
  IN_SETTING /// something staff do in the nursery
  HOME /// a strategy or activity shared with the parent for home
}

enum InterventionStatus {
  PLANNED
  ACTIVE
  DONE
  DISCONTINUED
}

/// A specific thing being DONE for an outcome — the "Do" of the graduated approach. Either
/// an in-setting strategy staff deliver, or a home activity shared with the parent.
///
/// Where a HOME activity is a generated worksheet, it links the existing worksheet engine by
/// id (`worksheetAssignmentId`) — that engine already carries parent assignment, completion,
/// and effectiveness (pre/post scores), so we reuse it rather than reinvent it. Kept a plain
/// nullable id, not an FK: not every intervention is a worksheet, and the link is loose by
/// design (same precedent as `ChildClaim.mergedFromPlaceholderId`).
model SupportIntervention {
  id        String         @id @default(cuid())
  outcomeId String
  outcome   SupportOutcome @relation(fields: [outcomeId], references: [id], onDelete: Cascade)

  kind        InterventionKind
  title       String
  description String?
  status      InterventionStatus @default(PLANNED)

  /// When this is a home worksheet, the `WorksheetAssignment` that carries it to the parent.
  worksheetAssignmentId String?

  createdById String?
  createdBy   User?   @relation("CreatedInterventions", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([outcomeId])
  @@map("support_interventions")
}

// ─── Early developmental review (~age 2) (F9) ────────────────────────────────

enum DevReviewStatus {
  DRAFT /// the lead is preparing the review summary
  SHARED /// shared with the guardian
  ACKNOWLEDGED /// the guardian has seen it (and may have responded)
}

/// A point-in-time developmental review at around age two — the age at which delays first
/// become reliably visible. A defined top-of-funnel instrument that pulls a child's
/// screening (F4), the parent-vs-educator concordance, and the recorded observations into
/// one plain-language snapshot the nursery shares with the family (and can hand to an onward
/// health contact).
///
/// This is the GENERIC well-child-review concept — NOT any one country's statutory check.
/// A statutory wrapper (e.g. England's Progress Check at Age Two + integrated review) is a
/// regional-config concern layered on top, never baked into the core.
///
/// Reuses the F4 screening ENGINE (it links the assessments; it does not re-implement
/// screening) and follows the F5/F6 nursery pattern: own model, anchored to the affiliation
/// (the consent anchor), created only while ACTIVE + consented, guardian-visible once shared.
model DevelopmentalReview {
  id      String @id @default(cuid())
  childId String
  child   Child  @relation("ChildDevReviews", fields: [childId], references: [id], onDelete: Cascade)

  affiliationId String
  affiliation   ChildAffiliation @relation(fields: [affiliationId], references: [id], onDelete: Cascade)
  facilityId    String
  facility      Facility         @relation("FacilityDevReviews", fields: [facilityId], references: [id], onDelete: Cascade)

  createdById String?
  createdBy   User?   @relation("CreatedDevReviews", fields: [createdById], references: [id], onDelete: SetNull)

  /// The child's age in months at review time (snapshot — the review is dated by this).
  ageMonths Int
  status    DevReviewStatus @default(DRAFT)
  /// Domains flagged at review, for quick display (the same 8-domain vocabulary).
  flaggedDomains String[] @default([])

  /// Which screenings informed it (loose ids — the screenings live in the assessments engine).
  educatorAssessmentId String?
  parentAssessmentId   String?

  /// A snapshot of what the review rests on — counts + concordance headline, not duplicated PHI.
  evidenceSummary Json?
  /// The plain-language review shared with the parent (editable before sharing).
  summary        String
  /// A short next-step suggestion, deliberately non-diagnostic (e.g. "continue to monitor").
  recommendation String?

  sharedAt       DateTime?
  acknowledgedAt DateTime?
  parentResponse String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([childId, status])
  @@index([facilityId, status])
  @@map("developmental_reviews")
}

// ─── Onward handover record (school transition / multi-agency) (F11) ─────────

enum HandoverRecipient {
  SCHOOL /// moving on to school / reception
  CLINICIAN /// into a diagnostic or therapy pathway
  OTHER
}

enum HandoverStatus {
  DRAFT /// assembled, being prepared — not yet disclosed
  SHARED /// disclosed onward, after the guardian authorised it
}

/// The child's identification + support story, assembled for the people who come next —
/// a receiving school, or a clinician. The nursery already holds all of it (observations,
/// screenings, reviews, concerns, support plans and what worked); this packages it so the
/// investment in early identification is not lost at the hand-off.
///
/// DISCLOSURE IS GUARDIAN-GATED. A handover leaves the setting only after the guardian has
/// authorised that specific onward disclosure (`guardianConsentedAt`) — assembling it is a
/// staff action; letting it go is the family's decision. Anchored to the affiliation, like
/// everything else a nursery holds about a child.
model HandoverRecord {
  id      String @id @default(cuid())
  childId String
  child   Child  @relation("ChildHandovers", fields: [childId], references: [id], onDelete: Cascade)

  affiliationId String
  affiliation   ChildAffiliation @relation(fields: [affiliationId], references: [id], onDelete: Cascade)
  facilityId    String
  facility      Facility         @relation("FacilityHandovers", fields: [facilityId], references: [id], onDelete: Cascade)

  createdById String?
  createdBy   User?   @relation("CreatedHandovers", fields: [createdById], references: [id], onDelete: SetNull)

  recipientType HandoverRecipient @default(SCHOOL)
  recipientName String?
  status        HandoverStatus    @default(DRAFT)

  /// The assembled snapshot at generation time (counts + summaries, not raw PHI dumps).
  snapshot Json
  /// A plain-language narrative of the story, editable before disclosure.
  summary  String

  /// The guardian's authorisation of THIS onward disclosure. Required before SHARED.
  guardianConsentedAt DateTime?
  sharedAt            DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([childId, status])
  @@index([facilityId, status])
  @@map("handover_records")
}
