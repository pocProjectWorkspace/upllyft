// ─── TREATMENT PLANS ─────────────────────────────────────

model TreatmentPlan {
  id          String              @id @default(cuid())
  caseId      String
  case        Case                @relation(fields: [caseId], references: [id], onDelete: Cascade)
  status      TreatmentPlanStatus @default(DRAFT)
  version     Int                 @default(1)
  content     Json
  createdById String
  createdBy   User                @relation("CreatedTreatmentPlans", fields: [createdById], references: [id])
  approvedAt  DateTime?
  expiresAt   DateTime?
  // --- UAE Phase 3: activation + review cadence ---
  frequency          String?
  sessionsPlanned    Int?
  reviewIntervalDays Int?
  activatedAt        DateTime?
  parentAcceptedAt   DateTime?
  reviews            CaseReview[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([caseId])
  @@index([status])
  @@map("treatment_plans")
}

// ─── CARE PLAN (Consultation → recurring session series) ─────────────────
// The keystone the source template lacked: a clinician-authored plan that
// auto-generates a dated recurring CaseSession series. Distinct from the thin
// TreatmentPlan (review-cadence only). See "Care Journey" handoff, Stage 3.

model CarePlan {
  id                   String                @id @default(cuid())
  caseId               String
  case                 Case                  @relation(fields: [caseId], references: [id], onDelete: Cascade)
  // Origin: the ClinicalRecord(CONSULTATION) that produced this plan (scalar, like other links in this schema)
  consultationRecordId String?
  consultationNotes    String?               // detailed consultation notes captured before the recommendation
  recommendation       CarePlanRecommendation @default(THERAPY)
  disciplines          TherapyDiscipline[]
  // Assigned lead therapist (User id, matching CaseSession.therapist) — scalar to avoid a User back-relation
  primaryTherapistId   String?
  // Recurring schedule inputs
  startDate            DateTime
  timeOfDay            String                // "16:00" — default/fallback time
  daysOfWeek           Int[]                 // 0=Sun … 6=Sat
  daySchedule          Json?                 // per-weekday time overrides, e.g. { "1": "16:00", "3": "15:00" }
  sessionCount         Int
  // Commercials
  packageName          String?
  unitPrice            Int                   @default(0) // whole currency units (₹)
  currency             String                @default("INR")
  totalAmount          Int                   @default(0)
  paymentStatus        CarePlanPaymentStatus @default(PENDING)
  // Branch data for non-booking recommendations
  reviewInWeeks        Int?                  // recommendation = NONE (monitor)
  externalReferralTarget String?             // recommendation = REFERRAL
  // Lifecycle
  status               CarePlanStatus        @default(DRAFT)
  parentAcceptedAt     DateTime?
  lockedAt             DateTime?
  createdById          String
  sessions             CaseSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([caseId])
  @@index([status])
  @@map("care_plans")
}

// Configurable defaults per recommendation type (pricing + day/count pattern).
// Seeded from handoff defaults; editable so clinics can tune without code changes.
model CarePlanPricingDefault {
  id                 String                 @id @default(cuid())
  recommendation     CarePlanRecommendation @unique
  label              String
  unitPrice          Int                    @default(0)
  currency           String                 @default("INR")
  defaultCount       Int                    @default(1)
  defaultDaysPerWeek Int                    @default(1)
  defaultDays        Int[]                  // suggested weekday numbers
  packageType        String?
  active             Boolean                @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("care_plan_pricing_defaults")
}

// ─── ASSESSMENT REVIEWS (Care Journey Stage 5) ───────────────────────────
// Formal single/MDT assessment run through 3 phases: Plan → Execution → MDT
// report. Ties per-discipline execution (each an AssessmentDiscipline linking
// to a ClinicalRecord) to a consolidated, consent-gated report. Replaces the
// prototype's localStorage. See handoff Stage 5.
model AssessmentReview {
  id                   String                @id @default(cuid())
  caseId               String
  case                 Case                  @relation(fields: [caseId], references: [id], onDelete: Cascade)
  type                 AssessmentReviewType  @default(SINGLE)
  phase                AssessmentPhase       @default(PLAN)
  title                String?
  // Plan phase
  scopeText            String?               // free-text assessment scope (objective, disciplines, sequence)
  scopeApproved        Boolean               @default(false)
  dayMode              String?               // single | multi
  questionnaireSent    Boolean               @default(false)
  schoolInputRequested Boolean               @default(false)
  paymentStatus        CarePlanPaymentStatus @default(PENDING)
  // Report phase
  meetingAt            DateTime?
  syncMode             String?               // sync | async
  reportText           String?
  approval             String?               // approved | changes | rejected
  reportDocumentId     String?
  recipients           Json?                 // { parent, school, doctor }
  sharedAt             DateTime?
  createdById          String
  disciplines          AssessmentDiscipline[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([caseId])
  @@index([phase])
  @@map("assessment_reviews")
}

model AssessmentDiscipline {
  id                 String                @id @default(cuid())
  assessmentReviewId String
  assessmentReview   AssessmentReview      @relation(fields: [assessmentReviewId], references: [id], onDelete: Cascade)
  discipline         TherapyDiscipline
  status             AssessmentExecStatus  @default(NOT_STARTED)
  assignee           String?
  clinicalRecordId   String?
  reportTitle        String?
  flagged            Boolean               @default(false) // added mid-scope via "flag a concern"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([assessmentReviewId, discipline])
  @@index([assessmentReviewId])
  @@map("assessment_disciplines")
}

// ─── CLIENT INTAKE (Care Journey Stage 1) ────────────────────────────────
// One stateful intake record per case (DRAFT → SUMMARISED). Captures Sections
// A–F once; consent toggles here are written through to CaseConsent so no
// downstream stage re-captures consent. See handoff Stage 1.
model CaseIntake {
  id                String      @id @default(cuid())
  caseId            String      @unique
  case              Case        @relation(fields: [caseId], references: [id], onDelete: Cascade)
  state             IntakeState @default(DRAFT)
  data              Json        @default("{}") // Sections A–F payload
  // Extracted highlights for downstream context (Triage left-rail etc.)
  presentingConcern String?
  referralQuestions String[]
  parentGoals       String[]
  urgencyFlag       String?
  aiSummary         String?
  // Section E consent toggles (source of truth mirrored into CaseConsent)
  consentAssessment Boolean     @default(false)
  consentTherapy    Boolean     @default(false)
  consentSharing    Boolean     @default(false)
  consentAi         Boolean     @default(false)
  recordedBy        String?
  summarisedAt      DateTime?
  createdById       String
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@map("case_intakes")
}

// ─── CASE BILLING ────────────────────────────────────────

model CaseBilling {
  id          String        @id @default(cuid())
  caseId      String
  case        Case          @relation(fields: [caseId], references: [id], onDelete: Cascade)
  sessionId   String?       @unique
  session     CaseSession?  @relation(fields: [sessionId], references: [id])
  serviceCode String?
  amount      Float
  status      BillingStatus @default(PENDING)
  paidAt      DateTime?
  invoiceUrl  String?
  // --- UAE Phase 2: payer-aware billing ---
  payerType          PayerType @default(SELF_PAY)
  insurancePolicyId  String?
  preAuthorizationId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([caseId])
  @@index([status])
  @@map("case_billing")
}

// ─── AUDIT LOG ───────────────────────────────────────────

model CaseAuditLog {
  id         String   @id @default(cuid())
  caseId     String
  case       Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation("CaseAuditLogs", fields: [userId], references: [id])
  action     String
  entityType String
