/// WHO answered a screening. Without this, a parent-report and a teacher-report of the
/// same child are indistinguishable rows — and multi-informant screening, where the
/// DISAGREEMENT between settings is the signal, is unrepresentable.
enum InformantType {
  PARENT /// guardian, reporting on the child at home
  EDUCATOR /// keyworker / teacher, reporting on the child in their setting
  CLINICIAN /// administered by a therapist during assessment
}

enum AnswerType {
  YES
  SOMETIMES
  /// The informant CAN observe this, but is genuinely unsure. Scored (0.7).
  NOT_SURE
  NO
  /// The informant had NO OPPORTUNITY to observe this — e.g. a keyworker asked about
  /// bedtime, or a parent asked about behaviour in a group of twenty. EXCLUDED from
  /// scoring entirely: it is neither numerator nor denominator.
  ///
  /// This is the difference between "I don't know" and "I can't know", and it is
  /// load-bearing for multi-informant screening. NOT_SURE scores 0.7 — worse than
  /// SOMETIMES. If an educator's unavoidable blind spots were scored that way, their
  /// report would run systematically hot, and the parent-vs-educator disagreement
  /// that early identification depends on would be an artefact of who can see what,
  /// not a signal about the child.
  NOT_OBSERVED
}

