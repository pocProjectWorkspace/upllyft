  updatedAt DateTime      @updatedAt

  @@index([userId])
  @@index([childId])
  @@index([updatedAt])
  @@map("mira_conversations")
}

model MiraMessage {
  id             String           @id @default(cuid())
  conversationId String
  conversation   MiraConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String // 'user' | 'assistant'
  content        String
  cards          Json? // MiraCard[] as JSON
  choices        Json? // string[] as JSON
  actions        Json? // MiraAction[] as JSON
  sentiment      String?
  createdAt      DateTime         @default(now())

  @@index([conversationId])
  @@index([createdAt])
  @@map("mira_messages")
}

// ── Phase 2: Consent, Billing, Messaging, Notifications ─────────────────

enum ConsentStatus {
  PENDING
  SENT
  SIGNED
  DECLINED
  EXPIRED
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  VOID
}

enum DevicePlatform {
  IOS
  ANDROID
  WEB
}

model ConsentForm {
  id          String        @id @default(cuid())
  patientId   String
  patient     User          @relation("ConsentFormPatient", fields: [patientId], references: [id])
  intakeId    String
  envelopeId  String?       @unique
  status      ConsentStatus @default(PENDING)
  sentAt      DateTime?
  signedAt    DateTime?
  documentUrl String?
  sentBy      String
  sentByUser  User          @relation("ConsentFormSentBy", fields: [sentBy], references: [id])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([patientId])
  @@index([intakeId])
  @@index([status])
  @@map("consent_forms")
}

model Credential {
  id             String    @id @default(cuid())
  therapistId    String
  therapist      User      @relation("TherapistCredentials", fields: [therapistId], references: [id])
  label          String    @default("")
  docType        String    @default("")
  fileName       String    @default("")
  fileUrl        String
  mimeType       String    @default("application/octet-stream")
  expiresAt      DateTime?
  verified       Boolean   @default(false)
  verifiedBy     String?
  verifiedAt     DateTime?
  uploadedBy     String
  uploadedByUser User      @relation("UploadedCredentials", fields: [uploadedBy], references: [id])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([therapistId])
  @@map("credentials")
}

model Invoice {
  id              String        @id @default(cuid())
  sessionId       String        @unique
  session         CaseSession   @relation(fields: [sessionId], references: [id])
  bookingId       String?       @unique
  booking         Booking?      @relation(fields: [bookingId], references: [id])
  patientId       String
  patient         User          @relation("InvoicePatient", fields: [patientId], references: [id])
  therapistId     String
  therapist       User          @relation("InvoiceTherapist", fields: [therapistId], references: [id])
  amount          Decimal
  currency        String        @default("AED")
  status          InvoiceStatus @default(DRAFT)
  stripePaymentId String?
  clinicName      String?
  issuedAt        DateTime?
  paidAt          DateTime?
  dueDate         DateTime?
  notes           String?
  // --- UAE Phase 2: payer-aware invoicing ---
  payerType         PayerType @default(SELF_PAY)
  insurancePolicyId String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  clinicId String?
  clinic   Clinic? @relation("ClinicInvoices", fields: [clinicId], references: [id])

  @@index([patientId])
  @@index([therapistId])
  @@index([status])
  @@index([clinicId])
  @@map("invoices")
}

model Conversation {
  id             String    @id @default(cuid())
  parentId       String
  parent         User      @relation("ParentConversations", fields: [parentId], references: [id])
  therapistId    String
  therapist      User      @relation("TherapistConversations", fields: [therapistId], references: [id])
  caseId         String?
  case           Case?     @relation(fields: [caseId], references: [id])
  participantIds String[]
  lastMessageAt  DateTime?
  messages       Message[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([parentId, therapistId])
  @@index([parentId])
  @@index([therapistId])
  @@index([caseId])
  @@map("conversations")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation("MessageSender", fields: [senderId], references: [id])
  body           String       @db.Text
  readAt         DateTime?
  createdAt      DateTime     @default(now())

  @@index([conversationId])
  @@index([senderId])
  @@map("messages")
}

model DeviceToken {
  id        String         @id @default(cuid())
  userId    String
  user      User           @relation("UserDeviceTokens", fields: [userId], references: [id])
  token     String         @unique
  platform  DevicePlatform
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([userId])
  @@map("device_tokens")
}

// ─── PDPL AUDIT LOG ─────────────────────────────────────────────────────

model AuditLog {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation("AuditLogs", fields: [userId], references: [id])
  resourceType String // e.g. 'CaseSession', 'ConsentForm'
  resourceId   String
  action       String // e.g. 'READ', 'CREATE', 'UPDATE', 'DELETE', 'EXPORT'
  metadata     Json?
  timestamp    DateTime @default(now())

  @@index([userId])
  @@index([resourceType])
  @@index([timestamp])
  @@map("audit_logs")
}

// ─── CLINIC (UAE Multi-tenant Foundation) ─────────────────────────────────

model Clinic {
  id             String             @id @default(cuid())
  name           String
  logoUrl        String?
  bannerUrl      String?
  primaryColor   String?
  secondaryColor String?
  accentColor    String?
  address        String?
  licenseNo      String?
  phone          String?
  email           String?
  country         String?
  description     String?
  website         String?
  rating          Float?             @default(0)
  totalReviews    Int                @default(0)
  specializations String[]           @default([])
  isPublic        Boolean            @default(true)
  // --- UAE regulatory context (Phase 0) ---
  licenseAuthority     LicenseAuthority?
  emirate              Emirate?
  complianceStatus     FacilityComplianceStatus @default(DRAFT)
  complianceReviewedAt DateTime?
  complianceReviewedBy String?
  // --- EHR integration (engagement-layer posture) ---
  ehrSystemName        String?
  nabidhFacilityCode   String?
  organizationId  String?
  organization   Organization?      @relation("OrganizationClinics", fields: [organizationId], references: [id])
  adminId        String             @unique
  admin          User               @relation("ClinicAdmin", fields: [adminId], references: [id])
  therapists     TherapistProfile[] @relation("ClinicTherapists")
  bookings       Booking[]          @relation("ClinicBookings")
  cases          Case[]             @relation("ClinicCases")
  children       Child[]
  invoices       Invoice[]          @relation("ClinicInvoices")
  consentTemplates ConsentTemplate[] @relation("ClinicConsentTemplates")
  leads            Lead[]             @relation("ClinicLeads")
  pathwayTemplates PathwayTemplate[]  @relation("ClinicPathways")
  ehrExports       EhrExport[]        @relation("ClinicEhrExports")
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([adminId])
  @@index([organizationId])
  @@map("clinics")
}
