// ─── CARE PLAN (Consultation → recurring session series) ─────────────────
// The keystone the source template lacked: a clinician-authored plan that
// auto-generates a dated recurring CaseSession series. Distinct from the thin
// TreatmentPlan (review-cadence only). See "Care Journey" handoff, Stage 3.

model CarePlan {
  id                     String                 @id @default(cuid())
  caseId                 String
  case                   Case                   @relation(fields: [caseId], references: [id], onDelete: Cascade)
  // Origin: the ClinicalRecord(CONSULTATION) that produced this plan (scalar, like other links in this schema)
  consultationRecordId   String?
  consultationNotes      String? // detailed consultation notes captured before the recommendation
  recommendation         CarePlanRecommendation @default(THERAPY)
  disciplines            TherapyDiscipline[]
  // Assigned lead therapist (User id, matching CaseSession.therapist) — scalar to avoid a User back-relation
  primaryTherapistId     String?
  // Recurring schedule inputs
  startDate              DateTime
  timeOfDay              String // "16:00" — default/fallback time
  daysOfWeek             Int[] // 0=Sun … 6=Sat
  daySchedule            Json? // per-weekday time overrides, e.g. { "1": "16:00", "3": "15:00" }
  sessionCount           Int
  // Commercials
  packageName            String?
  unitPrice              Int                    @default(0) // whole currency units (₹)
  currency               String                 @default("INR")
  totalAmount            Int                    @default(0)
  paymentStatus          CarePlanPaymentStatus  @default(PENDING)
  // Branch data for non-booking recommendations
  reviewInWeeks          Int? // recommendation = NONE (monitor)
  externalReferralTarget String? // recommendation = REFERRAL
  // Goals & IEPs care-plan creator (Care Journey §7)
  iepId                  String? // plan booked from an IEP
  mode                   String? // In-person | Teletherapy | Hybrid
  sessionDurationMin     Int? // 30 | 45 | 60
  parentHomeProgram      String?
  expectedOutcomes       String?
  reviewDate             DateTime?
  // Lifecycle
  status                 CarePlanStatus         @default(DRAFT)
  parentAcceptedAt       DateTime?
  lockedAt               DateTime?
  createdById            String
  sessions               CaseSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([caseId])
  @@index([status])
  @@map("care_plans")
}

// Configurable defaults per recommendation type (pricing + day/count pattern).
// Seeded from handoff defaults; editable so clinics can tune without code changes.
model CarePlanPricingDefault {
  id                 String                 @id @default(cuid())
  recommendation     CarePlanRecommendation @unique
  label              String
  unitPrice          Int                    @default(0)
  currency           String                 @default("INR")
  defaultCount       Int                    @default(1)
  defaultDaysPerWeek Int                    @default(1)
  defaultDays        Int[] // suggested weekday numbers
  packageType        String?
  active             Boolean                @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("care_plan_pricing_defaults")
}

// ─── ASSESSMENT REVIEWS (Care Journey Stage 5) ───────────────────────────
// Formal single/MDT assessment run through 3 phases: Plan → Execution → MDT
// report. Ties per-discipline execution (each an AssessmentDiscipline linking
// to a ClinicalRecord) to a consolidated, consent-gated report. Replaces the
// prototype's localStorage. See handoff Stage 5.
model AssessmentReview {
  id                   String                 @id @default(cuid())
  caseId               String
  case                 Case                   @relation(fields: [caseId], references: [id], onDelete: Cascade)
  type                 AssessmentReviewType   @default(SINGLE)
  phase                AssessmentPhase        @default(PLAN)
  title                String?
  // Plan phase
  scopeText            String? // free-text assessment scope (objective, disciplines, sequence)
  scopeApproved        Boolean                @default(false)
  dayMode              String? // single | multi
  questionnaireSent    Boolean                @default(false)
  schoolInputRequested Boolean                @default(false)
  paymentStatus        CarePlanPaymentStatus  @default(PENDING)
  // Report phase
  meetingAt            DateTime?
  syncMode             String? // sync | async
  reportText           String?
  approval             String? // approved | changes | rejected
  reportDocumentId     String?
  recipients           Json? // { parent, school, doctor }
  sharedAt             DateTime?
  createdById          String
  disciplines          AssessmentDiscipline[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([caseId])
  @@index([phase])
  @@map("assessment_reviews")
}

model AssessmentDiscipline {
  id                 String               @id @default(cuid())
  assessmentReviewId String
  assessmentReview   AssessmentReview     @relation(fields: [assessmentReviewId], references: [id], onDelete: Cascade)
  discipline         TherapyDiscipline
  status             AssessmentExecStatus @default(NOT_STARTED)
  assignee           String?
  clinicalRecordId   String?
  reportTitle        String?
  flagged            Boolean              @default(false) // added mid-scope via "flag a concern"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([assessmentReviewId, discipline])
  @@index([assessmentReviewId])
  @@map("assessment_disciplines")
}

// ─── CLIENT INTAKE (Care Journey Stage 1) ────────────────────────────────
// One stateful intake record per case (DRAFT → SUMMARISED). Captures Sections
// A–F once; consent toggles here are written through to CaseConsent so no
// downstream stage re-captures consent. See handoff Stage 1.
model CaseIntake {
  id                String      @id @default(cuid())
  caseId            String      @unique
  case              Case        @relation(fields: [caseId], references: [id], onDelete: Cascade)
  state             IntakeState @default(DRAFT)
  data              Json        @default("{}") // Sections A–F payload
  // Extracted highlights for downstream context (Triage left-rail etc.)
  presentingConcern String?
  referralQuestions String[]
  parentGoals       String[]
  urgencyFlag       String?
  aiSummary         String?
  // Section E consent toggles (source of truth mirrored into CaseConsent)
  consentAssessment Boolean     @default(false)
  consentTherapy    Boolean     @default(false)
  consentSharing    Boolean     @default(false)
  consentAi         Boolean     @default(false)
  recordedBy        String?
  summarisedAt      DateTime?
  createdById       String
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@map("case_intakes")
}

// ─── CASE BILLING ────────────────────────────────────────

model CaseBilling {
  id                 String        @id @default(cuid())
  caseId             String
  case               Case          @relation(fields: [caseId], references: [id], onDelete: Cascade)
  sessionId          String?       @unique
  session            CaseSession?  @relation(fields: [sessionId], references: [id])
  serviceCode        String?
  amount             Float
  status             BillingStatus @default(PENDING)
  paidAt             DateTime?
  invoiceUrl         String?
  // --- UAE Phase 2: payer-aware billing ---
  payerType          PayerType     @default(SELF_PAY)
  insurancePolicyId  String?
  preAuthorizationId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([caseId])
  @@index([status])
  @@map("case_billing")
}

// ─── AUDIT LOG ───────────────────────────────────────────

model CaseAuditLog {
  id         String   @id @default(cuid())
  caseId     String
  case       Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation("CaseAuditLogs", fields: [userId], references: [id])
  action     String
  entityType String
  entityId   String
  changes    Json?
  timestamp  DateTime @default(now())

  @@index([caseId])
  @@index([userId])
  @@index([timestamp])
  @@map("case_audit_logs")
}

// ─── CONSENT MANAGEMENT ──────────────────────────────────

model CaseConsent {
  id                  String          @id @default(cuid())
  caseId              String
  case                Case            @relation(fields: [caseId], references: [id], onDelete: Cascade)
  type                ConsentType
  grantedById         String
  grantedBy           User            @relation("CaseConsents", fields: [grantedById], references: [id])
  validFrom           DateTime        @default(now())
  validUntil          DateTime?
  revokedAt           DateTime?
  notes               String?
  // --- UAE Phase 1: actionable, versioned consent ---
  consentVersionId    String?
  consentVersion      ConsentVersion? @relation(fields: [consentVersionId], references: [id])
  purpose             String?
  recipient           String?
  scope               Json?
  grantedByGuardianId String?
  grantedByGuardian   Guardian?       @relation("ConsentGuardian", fields: [grantedByGuardianId], references: [id])
  consentFormId       String?

  createdAt DateTime @default(now())

  @@index([caseId])
  @@index([type])
  @@map("case_consents")
}

// ─── UAE CLINIC PHASE 1: IDENTITY, GUARDIAN, CONSENT VERSIONING, PRE-VISIT ──

model PatientIdentityDocument {
  id           String          @id @default(cuid())
  childId      String
  child        Child           @relation(fields: [childId], references: [id], onDelete: Cascade)
  type         IdentityDocType
  fileUrl      String
  uploadedById String
  uploadedBy   User            @relation("UploadedIdentityDocs", fields: [uploadedById], references: [id])
  createdAt    DateTime        @default(now())

  @@index([childId])
  @@map("patient_identity_documents")
}

model Guardian {
  id                    String               @id @default(cuid())
  childId               String
  child                 Child                @relation(fields: [childId], references: [id], onDelete: Cascade)
  userId                String?
  user                  User?                @relation("GuardianUser", fields: [userId], references: [id])
  fullName              String
  relationship          GuardianRelationship
  hasAuthorityToConsent Boolean              @default(false)
  isPrimaryContact      Boolean              @default(false)
  isEmergencyContact    Boolean              @default(false)
  phone                 String?
  email                 String?
  accessLevel           GuardianAccessLevel  @default(VIEW_ONLY)
  consentsGranted       CaseConsent[]        @relation("ConsentGuardian")
  childConsents         ChildConsent[]       @relation("ChildConsentGuardian")
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  @@index([childId])
  @@map("guardians")
}

model ConsentTemplate {
  id         String           @id @default(cuid())
  clinicId   String?
  clinic     Clinic?          @relation("ClinicConsentTemplates", fields: [clinicId], references: [id])
  /// Phase E: consent packs are per-FACILITY. A nursery needs its own — collected
  /// in bulk at enrolment, not per-case like a clinic's. Additive alongside clinicId.
  facilityId String?
  facility   Facility?        @relation("FacilityConsentTemplates", fields: [facilityId], references: [id])
  type       ConsentType
  name       String
  isActive   Boolean          @default(true)
  versions   ConsentVersion[]
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@index([clinicId])
  @@index([facilityId])
  @@index([type])
  @@map("consent_templates")
}

model ConsentVersion {
  id            String          @id @default(cuid())
  templateId    String
  template      ConsentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  version       Int
  purpose       String
  bodyUrl       String?
  bodyHash      String?
  publishedAt   DateTime        @default(now())
  consents      CaseConsent[]
  childConsents ChildConsent[]  @relation("ChildConsentVersion")

  @@unique([templateId, version])
  @@map("consent_versions")
}

model PreVisitTask {
  id          String             @id @default(cuid())
  childId     String
  child       Child              @relation(fields: [childId], references: [id], onDelete: Cascade)
  caseId      String?
  bookingId   String?
  type        PreVisitTaskType
  status      PreVisitTaskStatus @default(PENDING)
  label       String
  dueAt       DateTime?
  completedAt DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([childId])
  @@index([status])
  @@map("pre_visit_tasks")
}

// ─── UAE CLINIC PHASE 2: PAYER / INSURANCE / PRE-AUTHORISATION ──────────────

model InsurancePolicy {
  id                String             @id @default(cuid())
  childId           String
  child             Child              @relation(fields: [childId], references: [id], onDelete: Cascade)
  payerType         PayerType          @default(INSURANCE)
  insurerName       String?
  sponsorName       String?
  policyNumber      String?
  memberId          String?
  cardDocumentUrl   String?
  validFrom         DateTime?
  validUntil        DateTime?
  coPayPercent      Float?
  isActive          Boolean            @default(true)
  preAuthorizations PreAuthorization[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([childId])
  @@map("insurance_policies")
}

model PreAuthorization {
  id               String            @id @default(cuid())
  policyId         String
  policy           InsurancePolicy   @relation(fields: [policyId], references: [id], onDelete: Cascade)
  caseId           String?
  case             Case?             @relation(fields: [caseId], references: [id])
  serviceCode      String?
  preAuthNumber    String?
  status           PreAuthStatus     @default(PENDING)
  approvedSessions Int?
  usedSessions     Int               @default(0)
  validFrom        DateTime?
  validUntil       DateTime?
  denialReason     String?
  renewedFromId    String?           @unique
  renewedFrom      PreAuthorization? @relation("PreAuthRenewal", fields: [renewedFromId], references: [id])
