  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([caseId])
  @@map("mdt_reviews")
}

model MdtAttendee {
  id          String    @id @default(cuid())
  mdtReviewId String
  mdtReview   MdtReview @relation(fields: [mdtReviewId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation("MdtAttendee", fields: [userId], references: [id])
  required    Boolean   @default(true)
  attended    Boolean   @default(false)
  approvedAt  DateTime?

  @@unique([mdtReviewId, userId])
  @@index([mdtReviewId])
  @@map("mdt_attendees")
}

model SessionAddendum {
  id        String      @id @default(cuid())
  sessionId String
  session   CaseSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  authorId  String
  author    User        @relation("SessionAddendumAuthor", fields: [authorId], references: [id])
  content   String
  createdAt DateTime    @default(now())

  @@index([sessionId])
  @@map("session_addendums")
}

model CaseReview {
  id              String            @id @default(cuid())
  caseId          String
  case            Case              @relation(fields: [caseId], references: [id], onDelete: Cascade)
  treatmentPlanId String?
  treatmentPlan   TreatmentPlan?    @relation(fields: [treatmentPlanId], references: [id])
  triggerType     ReviewTriggerType
  status          ReviewStatus      @default(DUE)
  dueAt           DateTime?
  completedById   String?
  completedBy     User?             @relation("CaseReviewCompleter", fields: [completedById], references: [id])
  outcome         String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([caseId])
  @@index([status])
  @@map("case_reviews")
}

model EhrExport {
  id           String          @id @default(cuid())
  clinicId     String
  clinic       Clinic          @relation("ClinicEhrExports", fields: [clinicId], references: [id])
  resourceType String
  resourceId   String
  format       EhrExportFormat @default(PDF)
  status       EhrExportStatus @default(PENDING)
  payloadUrl   String?
  ehrRef       String?
  exportedById String?
  exportedBy   User?           @relation("EhrExporter", fields: [exportedById], references: [id])
  reconciledAt DateTime?
  error        String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([clinicId])
  @@index([resourceType, resourceId])
  @@index([status])
  @@map("ehr_exports")
}

// ─── UAE CLINIC PHASE 4: SAFETY / INCIDENT / DISCHARGE ──────────────────────

model CaseIncident {
  id               String           @id @default(cuid())
  caseId           String?
  case             Case?            @relation(fields: [caseId], references: [id])
  childId          String?
  raisedById       String
  raisedBy         User             @relation("IncidentRaiser", fields: [raisedById], references: [id])
  raisedFromModule String?
  category         IncidentCategory
  urgency          IncidentUrgency  @default(ROUTINE)
  status           IncidentStatus   @default(OPEN)
  ownerId          String?
  owner            User?            @relation("IncidentOwner", fields: [ownerId], references: [id])
  description      String
  clinicalDecision String?
  actionPlan       String?
  // --- Care Journey Stage 6: referral / escalation flow ---
  riskLabel        String? // free-text concern label (e.g. from Triage handoff)
  referralTarget   String? // external recipient (doctor, hospital, school…)
  reviewerNote     String?
  reviewerApproved Boolean          @default(false)
  consentObtained  Boolean          @default(false)
  shareScope       Json? // minimum-necessary sharing checklist
  followUpOutcome  String? // yes | no | pending
  sentAt           DateTime?
  closedAt         DateTime?
  closedById       String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([caseId])
  @@index([status])
  @@index([urgency])
  @@map("case_incidents")
}

model ExternalShare {
  id             String                @id @default(cuid())
  caseId         String?
  case           Case?                 @relation(fields: [caseId], references: [id])
  recipientName  String
  recipientType  ExternalRecipientType
  consentId      String
  token          String                @unique
  expiresAt      DateTime
  revokedAt      DateTime?
  accessCount    Int                   @default(0)
  lastAccessedAt DateTime?
  createdById    String
  createdBy      User                  @relation("ExternalShareCreator", fields: [createdById], references: [id])
  createdAt      DateTime              @default(now())

  @@index([caseId])
  @@index([token])
  @@map("external_shares")
}

// ─── CLINICAL TEMPLATE ENGINE ────────────────────────────
// Digital equivalents of the clinic paper forms (session notes, assessment
// reports, MDT reviews, discharge summaries, …). A ClinicalTemplate holds a
// versioned JSON `schema` (sections → fields); a ClinicalRecord is a filled
// instance on a case, storing captured `answers` as JSON.

model ClinicalTemplate {
  id             String               @id @default(cuid())
  code           String // stable code, e.g. "SLP_ASSESSMENT"
  name           String
  description    String?
  discipline     TherapyDiscipline
  activityType   ClinicalActivityType
  version        Int                  @default(1)
  schema         Json // ClinicalTemplateSchema (sections + fields)
  isGlobal       Boolean              @default(true)
  organizationId String?
  organization   Organization?        @relation("OrgClinicalTemplates", fields: [organizationId], references: [id])
  isActive       Boolean              @default(true)
  records        ClinicalRecord[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@unique([code, version, organizationId])
  @@index([discipline, activityType])
  @@index([organizationId])
  @@index([isActive])
  @@map("clinical_templates")
}

model ClinicalRecord {
  id                  String               @id @default(cuid())
  caseId              String
  case                Case                 @relation(fields: [caseId], references: [id], onDelete: Cascade)
  templateId          String
  template            ClinicalTemplate     @relation(fields: [templateId], references: [id])
  // Snapshot of the template identity at capture time (templates may version).
  templateCode        String
  templateVersion     Int                  @default(1)
  discipline          TherapyDiscipline
  activityType        ClinicalActivityType
  therapistId         String
  therapist           User                 @relation("ClinicalRecordAuthor", fields: [therapistId], references: [id])
  title               String
  answers             Json // ClinicalAnswers — captured field values keyed by field id
  status              ClinicalRecordStatus @default(DRAFT)
  signedAt            DateTime?
  signatureName       String?
  // Link to a generated report document (CaseDocument), when produced.
  reportDocumentId    String?
  // AI-generated clinical insights for the therapist (Anthropic Claude).
  insights            Json?
  insightsModel       String?
  insightsGeneratedAt DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([caseId])
  @@index([caseId, activityType])
  @@index([templateId])
  @@index([status])
  @@map("clinical_records")
}

enum TherapyDiscipline {
  SPEECH
  OCCUPATIONAL
  BEHAVIOUR_ABA
  PSYCHOLOGY
  SPECIAL_EDUCATION
  PHYSIOTHERAPY
  MEDICAL
  MULTIDISCIPLINARY
  UNIVERSAL
}

enum ClinicalActivityType {
  INTAKE
  SESSION_NOTE
  ASSESSMENT
  CONSULTATION
  MDT_REVIEW
  GOAL_PLAN
  PROGRESS_REVIEW
  DISCHARGE
}

enum ClinicalRecordStatus {
  DRAFT
  SIGNED
  AMENDED
}

// ─── UAE CLINIC PHASE 0 ENUMS ────────────────────────────

/// Health regulators AND education regulators. A facility's authority must match
/// its FacilityType (see FACILITY_CAPABILITIES in @upllyft/types): a nursery is
/// licensed by KHDA/ADEK/MOE, never by DHA. This is why a nursery cannot simply
/// be a Clinic — the clinic compliance gate would have to be loosened to admit it.
enum LicenseAuthority {
  DHA // Dubai Health Authority                              (health)
  DOH // Department of Health – Abu Dhabi                    (health)
  MOHAP // Ministry of Health and Prevention (other emirates)  (health)
  KHDA // Knowledge & Human Development Authority, Dubai     (education)
  ADEK // Dept. of Education & Knowledge, Abu Dhabi          (education)
  MOE // Ministry of Education                              (education)
  OTHER
}

enum Emirate {
  ABU_DHABI
  DUBAI
  SHARJAH
  AJMAN
  UMM_AL_QUWAIN
  RAS_AL_KHAIMAH
  FUJAIRAH
}

enum FacilityComplianceStatus {
  DRAFT
  IN_REVIEW
  ACTIVE
  SUSPENDED
}

